# ---------- Database (SQLite) ----------
# The database is a single file. On Liara/Docker it lives on a mounted disk so it
# survives redeploys. The path is ABSOLUTE on purpose (relative paths resolve next
# to prisma/schema.prisma, not to the mounted disk).
DATABASE_URL=file:/app/data/app.db
# For local development WITHOUT Docker, use a relative file instead, e.g.:
#   DATABASE_URL=file:./dev.db

# ---------- Backend ----------
NODE_ENV=production
BACKEND_PORT=4000
APP_TIMEZONE=Asia/Tehran

# JWT secrets — CHANGE THESE in production (use long random strings)
JWT_ACCESS_SECRET=change_me_access_secret_please_use_a_long_random_value
JWT_REFRESH_SECRET=change_me_refresh_secret_please_use_a_long_random_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — only needed when the frontend runs on a DIFFERENT origin (e.g. local
# `next dev` on :3000). In the single-service deployment the frontend is served
# from the same origin as the API, so CORS is not used.
CORS_ORIGIN=http://localhost:3000

# Booking rules (can be tuned without code changes)
BOOKING_MAX_DAYS_AHEAD=14
BOOKING_START_HOUR=8
BOOKING_END_HOUR=16

# Default seeded admin (created once on first boot)
SEED_ADMIN_MOBILE=09120000000
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_FIRST_NAME=مدیر
SEED_ADMIN_LAST_NAME=سیستم

# ---------- SMS (Phase 2 — provider abstracted, not yet wired) ----------
SMS_PROVIDER=console            # console | kavenegar | melipayamak
# SMS_API_KEY=
# SMS_SENDER=
