# ---------- Database ----------
POSTGRES_USER=mammut
POSTGRES_PASSWORD=mammut_secret
POSTGRES_DB=mammut_vip
# Connection string used by the backend (host "db" is the docker-compose service name)
DATABASE_URL=postgresql://mammut:mammut_secret@db:5432/mammut_vip?schema=public

# ---------- Backend ----------
NODE_ENV=production
BACKEND_PORT=4000
APP_TIMEZONE=Asia/Tehran

# JWT secrets — CHANGE THESE in production (use long random strings)
JWT_ACCESS_SECRET=change_me_access_secret_please_use_a_long_random_value
JWT_REFRESH_SECRET=change_me_refresh_secret_please_use_a_long_random_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:3000

# Booking rules (can be tuned without code changes)
BOOKING_MAX_DAYS_AHEAD=14
BOOKING_START_HOUR=8
BOOKING_END_HOUR=16

# Default seeded admin (created once on first boot)
SEED_ADMIN_MOBILE=09120000000
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_FIRST_NAME=مدیر
SEED_ADMIN_LAST_NAME=سیستم

# ---------- SMS (Phase 2 — provider abstracted, not yet wired) ----------
SMS_PROVIDER=console            # console | kavenegar | melipayamak
# SMS_API_KEY=
# SMS_SENDER=

# ---------- Frontend ----------
FRONTEND_PORT=3000
# Public base URL the browser uses to reach the API
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
